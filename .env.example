# Скопируйте в .env рядом с docker-compose.yml и заполните под прод.

# --- База данных (MariaDB) ---
DB_ROOT_PASSWORD=change_me_root
DB_NAME=dekanat
DB_USER=dekanat
DB_PASSWORD=change_me

# --- Публичные адреса ---
# API_URL — адрес, по которому браузер открывает приложение (через nginx, порт 80).
# К этому же адресу фронт подключает вебсокет Reflex. Подставьте IP или домен прода.
# ВАЖНО: значение вшивается в статику на этапе сборки фронта (docker compose build),
# поэтому при смене адреса фронт нужно пересобрать (--build).
API_URL=http://your-prod-host
DEPLOY_URL=http://your-prod-host
